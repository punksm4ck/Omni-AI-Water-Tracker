{
  "manifest_version": 3,
  "name": "Omni-AI Water Tracker",
  "version": "4.0",
  "description": "Live Olympic pool water consumption tracker for the top 10 AI platforms.",
  "content_scripts": [
    {
      "matches": [
        "*://gemini.google.com/*",
        "*://chatgpt.com/*",
        "*://chat.openai.com/*",
        "*://claude.ai/*",
        "*://copilot.microsoft.com/*",
        "*://www.perplexity.ai/*",
        "*://chat.deepseek.com/*",
        "*://www.meta.ai/*",
        "*://chat.mistral.ai/*",
        "*://poe.com/*",
        "*://grok.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}

